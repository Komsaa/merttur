# Veritabanı (Coolify'da PostgreSQL servisi ekle, bağlantı stringini buraya koy)
DATABASE_URL="postgresql://merttur:SIFRE@localhost:5432/merttur_db"

# NextAuth - güvenli rastgele string: openssl rand -base64 32
NEXTAUTH_SECRET="buraya-cok-gizli-bir-string-koy-32-karakter-min"
NEXTAUTH_URL="https://merttur.com"

# İlk admin kullanıcıları (seed script için)
ADMIN_EMAIL_1="sen@merttur.com"
ADMIN_PASSWORD_1="guclu-sifre-1"
ADMIN_NAME_1="Admin - Sen"

ADMIN_EMAIL_2="baban@merttur.com"
ADMIN_PASSWORD_2="guclu-sifre-2"
ADMIN_NAME_2="Admin - Baban"

ADMIN_EMAIL_3="abin@merttur.com"
ADMIN_PASSWORD_3="guclu-sifre-3"
ADMIN_NAME_3="Admin - Abin"

# Dosya yükleme klasörü (VPS'te mutlak yol)
UPLOAD_DIR="/var/www/merttur/uploads"
UPLOAD_URL_BASE="https://merttur.com/uploads"

# WhatsApp Bot (Baileys) - opsiyonel
WHATSAPP_BOT_ENABLED="false"
WHATSAPP_GROUP_NAME="Mert Tur Yakıt"  # Grup adı tam olarak böyle olmalı
